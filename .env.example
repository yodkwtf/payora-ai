# Copy this file to .env.local and fill in your own values.
# All NEXT_PUBLIC_* values are exposed to the browser (this is expected for the
# Supabase anon key, which is safe to ship publicly when RLS is enabled).

# --- AI features (optional) ---
# Powers AI Insights, Ask AI, and the Add-form auto-fill. The app works without it.
# Server-side only (never exposed to the browser). Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# --- Accounts & cloud sync (optional) ---
# Without these, the app still runs fully in guest mode (data stays on-device).
# See guide.md for step-by-step Supabase setup.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- SEO / Open Graph (optional) ---
# Your deployed site URL, used to build absolute metadata/OG image URLs.
NEXT_PUBLIC_SITE_URL=https://your-domain.com
